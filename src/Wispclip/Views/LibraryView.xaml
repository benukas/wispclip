<UserControl x:Class="Wispclip.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="248"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="28,24,16,24">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,22">
                <TextBlock Text="Library" Style="{StaticResource PageTitle}"/>
                <TextBlock x:Name="CountText"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{StaticResource TextDimBrush}"/>
                <TextBlock x:Name="LibraryStatus"
                           Margin="0,3,0,0"
                           FontSize="11"
                           Foreground="{StaticResource TextFaintBrush}"/>
            </StackPanel>

            <Grid>
                <ScrollViewer x:Name="CardsScroll" VerticalScrollBarVisibility="Auto" ScrollChanged="CardsScroll_ScrollChanged">
                    <ItemsControl x:Name="ClipsList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Width tracks ClipsList.Tag, recomputed on resize (see
                                     CardsScroll_ScrollChanged) so a row always fills the
                                     available width edge-to-edge instead of a fixed size
                                     leaving a whole extra column's worth of space unused. -->
                                <Border x:Name="ClipCard"
                                        Width="{Binding ElementName=ClipsList, Path=Tag}"
                                        Margin="0,0,16,16"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource EdgeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="Card_Click">
                                    <Border.ContextMenu>
                                        <ContextMenu x:Name="CardMenu">
                                            <MenuItem Header="Edit clip" Click="Menu_Play"/>
                                            <MenuItem Header="Rename..." Click="Menu_Rename"/>
                                            <MenuItem Header="Copy file path" Click="Menu_CopyPath"/>
                                            <MenuItem Header="Show in Explorer" Click="Menu_Reveal"/>
                                            <MenuItem Header="Delete" Click="Menu_Delete"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="158"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="{StaticResource Panel2Brush}"
                                                CornerRadius="7,7,0,0"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Image Source="{Binding Thumb}" Stretch="UniformToFill"/>
                                                <Border x:Name="HoverShade"
                                                        Background="#4D000000"
                                                        Opacity="0"/>
                                                <Border Background="#D9000000"
                                                        CornerRadius="4"
                                                        Padding="7,3"
                                                        Margin="0,9,9,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding DurationText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <!-- Single overflow affordance instead of three competing
                                                     buttons; it opens the same context menu already wired
                                                     up for right-click. Sits over the thumbnail so revealing
                                                     it on hover never changes card height (no WrapPanel bounce). -->
                                                <Button x:Name="OverflowBtn"
                                                        Click="Overflow_Click"
                                                        Margin="9,9,0,0"
                                                        Padding="6"
                                                        MinWidth="0"
                                                        MinHeight="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="#D9000000"
                                                        BorderThickness="0"
                                                        Opacity="0"
                                                        IsHitTestVisible="False"
                                                        ToolTip="More actions">
                                                    <Path Style="{StaticResource ButtonIcon}"
                                                          Width="12" Height="12"
                                                          Data="M2,5 A2,2 0 1 1 2,9 A2,2 0 1 1 2,5 Z M8,5 A2,2 0 1 1 8,9 A2,2 0 1 1 8,5 Z M14,5 A2,2 0 1 1 14,9 A2,2 0 1 1 14,5 Z"/>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           Margin="0,1,10,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- Plain colored label instead of a bordered pill: the
                                                     accent color alone signals status, no chip chrome needed. -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Kind}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </Grid>

                                            <TextBlock Text="{Binding Meta}"
                                                       Margin="0,6,0,0"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextFaintBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="ClipCard" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ClipCard" Property="BorderBrush" Value="{StaticResource StrongEdgeBrush}"/>
                                        <Setter TargetName="HoverShade" Property="Opacity" Value="1"/>
                                        <Setter TargetName="OverflowBtn" Property="Opacity" Value="1"/>
                                        <Setter TargetName="OverflowBtn" Property="IsHitTestVisible" Value="True"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="ClipCard" Property="BorderBrush" Value="{StaticResource SelectedEdgeBrush}"/>
                                        <Setter TargetName="ClipCard" Property="Background" Value="{StaticResource SelectedBrush}"/>
                                        <Setter TargetName="OverflowBtn" Property="Opacity" Value="1"/>
                                        <Setter TargetName="OverflowBtn" Property="IsHitTestVisible" Value="True"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border x:Name="EmptyState"
                        Width="380"
                        Padding="32"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Image Source="/Assets/wispclip-small.png"
                               Width="40"
                               Height="40"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Opacity="0.5"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>
                        <TextBlock x:Name="EmptyTitle"
                                   Text="No clips yet"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EmptyHint"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   LineHeight="19"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!-- Filter sidebar: a proper full-bleed pane (flush to the window's top/right/bottom
             edges, just a hairline left border) rather than a floating inset card, so it reads
             as a real dock instead of a box dropped into leftover space. -->
        <Border Grid.Column="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}"
                BorderThickness="1,0,0,0">
            <StackPanel Margin="20,24,20,24">
                <TextBlock Text="Search" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="SearchBox"
                         Margin="0,0,0,18"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock Text="Type" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                <StackPanel Margin="0,0,0,16">
                    <RadioButton x:Name="FilterAll"
                                 Style="{StaticResource FilterTab}"
                                 Content="All"
                                 GroupName="KindFilter"
                                 IsChecked="True"
                                 Checked="KindFilter_Checked"/>
                    <RadioButton x:Name="FilterReplay"
                                 Style="{StaticResource FilterTab}"
                                 Content="Replays"
                                 GroupName="KindFilter"
                                 Checked="KindFilter_Checked"/>
                    <RadioButton x:Name="FilterRecording"
                                 Style="{StaticResource FilterTab}"
                                 Content="Recordings"
                                 GroupName="KindFilter"
                                 Checked="KindFilter_Checked"/>
                    <RadioButton x:Name="FilterEdited"
                                 Style="{StaticResource FilterTab}"
                                 Content="Edited"
                                 GroupName="KindFilter"
                                 Checked="KindFilter_Checked"/>
                </StackPanel>

                <TextBlock Text="Sort by" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="SortCombo"
                          Margin="0,0,0,18"
                          SelectedIndex="0"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="Newest first"/>
                    <ComboBoxItem Content="Oldest first"/>
                    <ComboBoxItem Content="Largest first"/>
                    <ComboBoxItem Content="Name A-Z"/>
                </ComboBox>

                <Separator Margin="0,0,0,14"/>

                <Button Click="OpenFolder_Click"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        ToolTip="Open the clips folder">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="M1,3 H7 L9,5 H15 V14 H1 Z M2,6 V13 H14 V6 Z"
                              Margin="0,0,8,0"/>
                        <TextBlock Text="Open folder" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="Refresh_Click"
                        HorizontalAlignment="Stretch"
                        ToolTip="Refresh library">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="M8,1 A7,7 0 1 1 2.2,4 L0,4 L0,9 L5,9 L5,7 L2.7,7 A5,5 0 1 0 4,3 Z"
                              Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
