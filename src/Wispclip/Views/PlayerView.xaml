<UserControl x:Class="Wispclip.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">
    <Grid Background="{StaticResource BgBrush}" MouseLeftButtonDown="Backdrop_Click">
        <Border Background="{StaticResource BgBrush}"
                MouseLeftButtonDown="Panel_Click">
            <Grid x:Name="EditorRoot" Margin="24,18,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRowDef" Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="HeaderBar" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="DirtyDot"
                                   Text="Changes saved on close"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Visibility="Hidden"/>
                        <Button Padding="12,7"
                                Click="Close_Click"
                                ToolTip="Close editor (Esc)">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M7,1 L1,7 L7,13 L7,9 L15,9 L15,5 L7,5 Z"
                                      Margin="0,0,8,0"/>
                                <TextBlock Text="Back to library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border x:Name="PreviewBorder"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource EdgeBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        ClipToBounds="True"
                        MinHeight="300">
                    <Grid x:Name="PreviewHost" SizeChanged="PreviewHost_SizeChanged">
                        <Border x:Name="SceneViewport"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ClipToBounds="True">
                            <Grid x:Name="Scene"
                                  Background="Transparent"
                                  MouseLeftButtonDown="Scene_MouseDown">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="SceneScale"/>
                                        <TranslateTransform x:Name="SceneTranslate"/>
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <Border x:Name="SceneBg"/>
                                <Image x:Name="SceneBgImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                                <Border x:Name="SceneVignette" Visibility="Collapsed"/>
                                <Grid x:Name="CardHost"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Border x:Name="CardShadow" Background="#000000"/>
                                    <Grid x:Name="CardClip">
                                        <MediaElement x:Name="Media"
                                                      LoadedBehavior="Manual"
                                                      ScrubbingEnabled="True"
                                                      Stretch="UniformToFill"
                                                      MediaOpened="Media_Opened"
                                                      MediaEnded="Media_Ended"
                                                      MediaFailed="Media_Failed"/>
                                    </Grid>
                                </Grid>
                                <Canvas x:Name="FocusLayer" IsHitTestVisible="False">
                                    <Grid x:Name="FocusMarker" Visibility="Collapsed">
                                        <Ellipse Width="26"
                                                 Height="26"
                                                 Stroke="{StaticResource AccentBrush}"
                                                 StrokeThickness="1.5"
                                                 Opacity="0.9"/>
                                        <Ellipse Width="4"
                                                 Height="4"
                                                 Fill="{StaticResource AccentBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                    </Grid>
                                </Canvas>
                            </Grid>
                        </Border>

                        <Border x:Name="ZoomPlacementBanner"
                                Margin="18"
                                Padding="12,9"
                                Background="{StaticResource PrimaryBrush}"
                                BorderBrush="{StaticResource PrimaryHoverBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ZoomPlacementText"
                                           Text="Click the preview to place the zoom focus."
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Content="Done placing zoom"
                                        Margin="14,0,0,0"
                                        Padding="10,6"
                                        Click="DoneZoomPlacement_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel x:Name="EditorControls" Grid.Row="2">
                    <Grid Margin="2,12,2,7">
                        <TextBlock Text="Trim"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TrimText"
                                   HorizontalAlignment="Right"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>

                    <Border Height="74"
                            Background="{StaticResource Panel2Brush}"
                            BorderBrush="{StaticResource EdgeBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Canvas x:Name="Timeline"
                                Background="Transparent"
                                ClipToBounds="True"
                                SizeChanged="Timeline_SizeChanged"
                                MouseLeftButtonDown="Timeline_MouseDown"
                                MouseMove="Timeline_MouseMove"
                                MouseLeftButtonUp="Timeline_MouseUp"
                                LostMouseCapture="Timeline_LostMouseCapture"/>
                    </Border>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <WrapPanel VerticalAlignment="Center">
                            <Button Padding="10,8"
                                    Margin="0,0,5,0"
                                    Click="JumpStart_Click"
                                    ToolTip="Jump to start (Home)">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M1,1 H3 V13 H1 Z M13,1 L5,7 L13,13 Z"/>
                            </Button>
                            <Button Padding="10,8"
                                    Margin="0,0,5,0"
                                    Click="PrevFrame_Click"
                                    ToolTip="Previous frame (,)">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M11,1 L3,7 L11,13 Z"/>
                            </Button>
                            <Button x:Name="PlayBtn"
                                    MinWidth="78"
                                    Click="Play_Click"
                                    ToolTip="Play or pause (Space)">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="PlayIcon"
                                          Style="{StaticResource ButtonIcon}"
                                          Data="M2,1 L13,7 L2,13 Z"
                                          Margin="0,0,8,0"/>
                                    <TextBlock x:Name="PlayLabel"
                                               Text="Play"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Padding="10,8"
                                    Margin="5,0,0,0"
                                    Click="NextFrame_Click"
                                    ToolTip="Next frame (.)">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M3,1 L11,7 L3,13 Z"/>
                            </Button>
                            <Button Padding="10,8"
                                    Margin="5,0,0,0"
                                    Click="JumpEnd_Click"
                                    ToolTip="Jump to end (End)">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M11,1 H13 V13 H11 Z M1,1 L9,7 L1,13 Z"/>
                            </Button>
                            <TextBlock x:Name="TimeText"
                                       Text="0:00 / 0:00"
                                       Margin="12,0,0,0"
                                       Foreground="{StaticResource TextDimBrush}"
                                       VerticalAlignment="Center"
                                       MinWidth="96"/>
                            <ToggleButton x:Name="LoopBtn"
                                          Content="Loop"
                                          Padding="10,7"
                                          FontSize="11"
                                          Margin="6,0,0,0"
                                          Click="Loop_Click"
                                          ToolTip="Loop the selected range"/>
                            <ComboBox x:Name="SpeedCombo"
                                      Width="62"
                                      Margin="8,0,0,0"
                                      SelectionChanged="Speed_Changed"
                                      ToolTip="Playback speed"/>
                            <Button x:Name="MuteBtn"
                                    Padding="10,8"
                                    Margin="10,0,0,0"
                                    Click="Mute_Click"
                                    ToolTip="Mute preview">
                                <Path x:Name="MuteIcon"
                                      Style="{StaticResource ButtonIcon}"
                                      Data="M1,5 H4 L8,2 V12 L4,9 H1 Z M10.5,4 A4,4 0 0 1 10.5,10 A6.2,6.2 0 0 0 10.5,4 Z"/>
                            </Button>
                            <Slider x:Name="Vol"
                                    Width="84"
                                    Minimum="0"
                                    Maximum="1"
                                    Value="0.8"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    ValueChanged="Vol_ValueChanged"/>
                            <Button Padding="10,8"
                                    Margin="12,0,0,0"
                                    Click="Fullscreen_Click"
                                    ToolTip="Fullscreen (F)">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="M1,1 H6 V3 H3 V6 H1 Z M15,1 V6 H13 V3 H10 V1 Z M1,10 H3 V13 H6 V15 H1 Z M13,10 H15 V15 H10 V13 H13 Z"/>
                            </Button>
                        </WrapPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Click="SetIn_Click"
                                    Margin="0,0,6,0"
                                    ToolTip="Set trim start at the playhead ([)">
                                <TextBlock x:Name="SetStartLabel" Text="Start at 0:00"/>
                            </Button>
                            <Button Click="SetOut_Click"
                                    Margin="0,0,6,0"
                                    ToolTip="Set trim end at the playhead (])">
                                <TextBlock x:Name="SetEndLabel" Text="End at 0:00"/>
                            </Button>
                            <Button Content="Use full clip"
                                    Click="ClearTrim_Click"
                                    ToolTip="Clear the selected range"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="270"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource EdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="14,11">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Effects"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="78"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="78"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Background"
                                               Foreground="{StaticResource TextFaintBrush}"
                                               FontSize="10"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <ComboBox x:Name="BgStyleCombo"
                                              Grid.Column="1"
                                              SelectionChanged="BgStyle_Changed"/>
                                    <TextBlock Grid.Column="3"
                                               Text="Frame"
                                               Foreground="{StaticResource TextFaintBrush}"
                                               FontSize="10"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="PadSlider"
                                            Grid.Column="4"
                                            Minimum="3"
                                            Maximum="16"
                                            VerticalAlignment="Center"
                                            ValueChanged="BgParam_Changed"/>
                                    <TextBlock Grid.Column="6"
                                               Text="Corners"
                                               Foreground="{StaticResource TextFaintBrush}"
                                               FontSize="10"
                                               Margin="0,0,7,0"
                                               VerticalAlignment="Center"/>
                                    <Slider x:Name="RadiusSlider"
                                            Grid.Column="7"
                                            Minimum="0"
                                            Maximum="48"
                                            VerticalAlignment="Center"
                                            ValueChanged="BgParam_Changed"/>
                                    <Button x:Name="AddZoomBtn"
                                            Grid.Column="9"
                                            Padding="10,7"
                                            Click="AddZoom_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="M7,1 A6,6 0 1 0 7,13 A6,6 0 1 0 7,1 M6,4 H8 V6 H10 V8 H8 V10 H6 V8 H4 V6 H6 Z M11,11 L16,16 L14,18 L9,13 Z"
                                                  Margin="0,0,7,0"/>
                                            <TextBlock x:Name="AddZoomLabel"
                                                       Text="Add zoom"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="2"
                                        Margin="0,12,0,0"
                                        Padding="0,11,0,0"
                                        BorderBrush="{StaticResource EdgeBrush}"
                                        BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Fades"
                                                   Foreground="{StaticResource TextFaintBrush}"
                                                   FontSize="10"
                                                   Margin="0,0,14,0"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="VideoFadeCheck"
                                                  Content="Video"
                                                  VerticalAlignment="Center"
                                                  Click="VideoFade_Changed"
                                                  ToolTip="Fade the video from and to black"/>
                                        <Slider x:Name="VideoFadeSlider"
                                                Width="92"
                                                Minimum="0.1"
                                                Maximum="2"
                                                Margin="10,0,7,0"
                                                VerticalAlignment="Center"
                                                ValueChanged="VideoFadeLen_Changed"/>
                                        <TextBlock x:Name="VideoFadeText"
                                                   Width="30"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Border Width="1"
                                                Height="18"
                                                Margin="16,0"
                                                Background="{StaticResource EdgeBrush}"/>
                                        <CheckBox x:Name="AudioFadeCheck"
                                                  Content="Audio"
                                                  VerticalAlignment="Center"
                                                  Click="AudioFade_Changed"
                                                  ToolTip="Fade the audio in and out"/>
                                        <Slider x:Name="AudioFadeSlider"
                                                Width="92"
                                                Minimum="0.1"
                                                Maximum="2"
                                                Margin="10,0,7,0"
                                                VerticalAlignment="Center"
                                                ValueChanged="AudioFadeLen_Changed"/>
                                        <TextBlock x:Name="AudioFadeText"
                                                   Width="30"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="3" Margin="0,11,0,0">
                                    <TextBlock x:Name="ZoomHint"
                                               Foreground="{StaticResource TextFaintBrush}"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Text="Add a zoom at the playhead, then place its focus in the preview."/>
                                    <Grid x:Name="ZoomEditor" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Zoom"
                                                   Foreground="{StaticResource TextFaintBrush}"
                                                   FontSize="10"
                                                   Margin="0,0,7,0"
                                                   VerticalAlignment="Center"/>
                                        <Slider x:Name="ZoomLevelSlider"
                                                Grid.Column="1"
                                                Minimum="1.2"
                                                Maximum="4"
                                                VerticalAlignment="Center"
                                                ValueChanged="ZoomParam_Changed"/>
                                        <TextBlock x:Name="ZoomLevelText"
                                                   Grid.Column="2"
                                                   FontSize="10"
                                                   Margin="5,0,0,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="Ease"
                                                   Foreground="{StaticResource TextFaintBrush}"
                                                   FontSize="10"
                                                   Margin="6,0,7,0"
                                                   VerticalAlignment="Center"/>
                                        <Slider x:Name="RampSlider"
                                                Grid.Column="4"
                                                Minimum="0.2"
                                                Maximum="1.5"
                                                VerticalAlignment="Center"
                                                ValueChanged="ZoomParam_Changed"/>
                                        <StackPanel Grid.Column="6"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Length"
                                                       Foreground="{StaticResource TextFaintBrush}"
                                                       FontSize="10"
                                                       Margin="0,0,7,0"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="-0.5s"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,0,5,0"
                                                    Click="ShrinkZoom_Click"
                                                    ToolTip="Shorten this zoom"/>
                                            <Button Content="+0.5s"
                                                    Style="{StaticResource CompactButton}"
                                                    Margin="0,0,9,0"
                                                    Click="GrowZoom_Click"
                                                    ToolTip="Lengthen this zoom"/>
                                            <TextBlock x:Name="ZoomRangeText"
                                                       Margin="0,0,9,0"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextDimBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="Remove"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="9,6"
                                                    FontSize="11"
                                                    Click="RemoveZoom_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource EdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="14,11">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Export"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ExportSummaryText"
                                               Text="Full clip"
                                               Margin="0,5,0,0"
                                               FontSize="10"
                                               Foreground="{StaticResource TextFaintBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Resolution"
                                                   Foreground="{StaticResource TextFaintBrush}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ResolutionCombo"
                                                  Grid.Column="1"
                                                  Margin="10,0,0,0"
                                                  SelectionChanged="Resolution_Changed"/>
                                    </Grid>
                                </StackPanel>

                                <Button x:Name="ExportBtn"
                                        Grid.Row="2"
                                        Style="{StaticResource AccentButton}"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Stretch"
                                        Click="Export_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Width="13"
                                              Height="13"
                                              Stretch="Uniform"
                                              Fill="#090A0C"
                                              Data="M7,1 H9 V9 L12,6 L14,8 L8,14 L2,8 L4,6 L7,9 Z M2,15 H14 V17 H2 Z"
                                              Margin="0,0,8,0"/>
                                        <TextBlock Text="Export video"
                                                   Foreground="#090A0C"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="PlayerStatus"
                               Margin="2,8,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextDimBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
