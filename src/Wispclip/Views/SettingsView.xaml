<UserControl x:Class="Wispclip.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900"
                    Margin="28,24,28,24"
                    HorizontalAlignment="Center">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Settings" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="Tune capture once, then leave the recorder in the tray."
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="{StaticResource TextDimBrush}"/>
            </StackPanel>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Capture quality"
                               Style="{StaticResource SectionHeader}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Display" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="MonitorCombo"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Frame rate" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="FpsCombo">
                                <ComboBoxItem Content="30 fps" Tag="30"/>
                                <ComboBoxItem Content="60 fps" Tag="60"/>
                                <ComboBoxItem Content="120 fps" Tag="120"/>
                                <ComboBoxItem Content="144 fps" Tag="144"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Codec" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CodecCombo">
                                <ComboBoxItem Content="H.264" Tag="h264"/>
                                <ComboBoxItem Content="H.265" Tag="hevc"/>
                                <ComboBoxItem Content="AV1 (supported GPUs)" Tag="av1"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,18,0,0">
                        <DockPanel>
                            <TextBlock Text="Quality" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="QualityLabel"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="QualitySlider"
                                Minimum="15"
                                Maximum="35"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="Quality_ValueChanged"/>
                        <TextBlock Text="CQ 22 is the recommended balance. Lower values keep more detail and create larger files."
                                   Margin="0,5,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0">
                        <CheckBox x:Name="PerfModeCheck"
                                  Content="Performance mode"
                                  ToolTip="Uses the fastest encoder presets to further reduce GPU load while capturing. The quality target stays the same, so files get slightly larger. Try this if you notice any FPS impact in games."/>
                        <TextBlock Text="Fastest encoder presets for minimal in-game impact. Slightly larger files at the same quality. Longer replay segments (fewer keyframes) also reduce load."
                                   Margin="27,6,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Replay buffer" Style="{StaticResource SectionHeader}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Protected duration" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="ReplayLenCombo">
                                <ComboBoxItem Content="15 seconds" Tag="15"/>
                                <ComboBoxItem Content="30 seconds" Tag="30"/>
                                <ComboBoxItem Content="1 minute" Tag="60"/>
                                <ComboBoxItem Content="2 minutes" Tag="120"/>
                                <ComboBoxItem Content="5 minutes" Tag="300"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <CheckBox x:Name="AutoStartCheck"
                                      Content="Arm the replay buffer when Wispclip opens"/>
                            <TextBlock Text="The buffer is the default recorder mode and stays ready in the tray."
                                       Margin="27,6,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Windows startup" Style="{StaticResource SectionHeader}"/>
                    <CheckBox x:Name="LaunchWithWindowsCheck"
                              Content="Start Wispclip when I sign in to Windows"/>
                    <TextBlock Text="Wispclip starts quietly in the tray and appears in Windows Settings under Apps, Startup."
                               Margin="27,6,0,14"
                               FontSize="11"
                               Foreground="{StaticResource TextDimBrush}"/>
                    <CheckBox x:Name="CloseToTrayCheck"
                              Content="Keep recording in the tray when the window is closed"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Audio" Style="{StaticResource SectionHeader}"/>
                    <CheckBox x:Name="SysAudioCheck"
                              Content="Capture game and system audio"
                              Margin="0,0,0,10"/>
                    <CheckBox x:Name="MicCheck"
                              Content="Capture microphone on a separate track"
                              Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Microphone" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="MicCombo"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Audio delay (ms)"
                                       Style="{StaticResource FieldLabel}"
                                       ToolTip="Use a positive number when audio plays before the picture."/>
                            <TextBox x:Name="DelayBox"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Files" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Clips folder" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,16">
                        <Button Content="Browse"
                                DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Click="Browse_Click"/>
                        <TextBox x:Name="OutDirBox"/>
                    </DockPanel>
                    <CheckBox x:Name="OverlayCheck"
                              Content="Show a click-through notification when a clip is saved"
                              ToolTip="The notification does not steal focus from borderless fullscreen games."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Select a field, then press the key combination."
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Save clip" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="HkSaveBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="HotkeyBox_KeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Full recording" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="HkRecordBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="HotkeyBox_KeyDown"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Replay buffer" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="HkBufferBox"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewKeyDown="HotkeyBox_KeyDown"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Capture engine" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="FFmpeg" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="FfmpegStatusText"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="Active pipeline" Style="{StaticResource FieldLabel}"/>
                    <TextBlock x:Name="PipelineText"
                               TextWrapping="Wrap"
                               FontSize="12"
                               LineHeight="18"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="Custom FFmpeg folder" Style="{StaticResource FieldLabel}"/>
                    <DockPanel Margin="0,0,0,14">
                        <Button Content="Browse"
                                DockPanel.Dock="Right"
                                Margin="8,0,0,0"
                                Click="BrowseFfmpeg_Click"/>
                        <TextBox x:Name="FfmpegDirBox"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Detect best pipeline"
                                Click="Redetect_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="Open log" Click="OpenLog_Click"/>
                    </StackPanel>

                    <TextBlock Text="Live diagnostics"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,18,0,0"/>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Encode speed"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatSpeedText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Duplicated frames"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatDupText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Dropped frames"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatDropText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="App CPU / RAM"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatAppUsageText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Encoder CPU / RAM"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatEncUsageText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last clip save"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            <TextBlock x:Name="StatSaveTimeText"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="StatHintText"
                               Text="Start the replay buffer or a recording to see live stats."
                               Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextDimBrush}"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,6,0,0">
                <TextBlock x:Name="ApplyStatus"
                           Foreground="{StaticResource TextDimBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Apply changes"
                        Style="{StaticResource AccentButton}"
                        Padding="22,9"
                        HorizontalAlignment="Right"
                        Click="Apply_Click"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
