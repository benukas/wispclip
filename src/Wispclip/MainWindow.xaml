<Window x:Class="Wispclip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Wispclip.Views"
        Title="Wispclip"
        Icon="/Assets/wispclip.ico"
        Width="1240"
        Height="800"
        MinWidth="1040"
        MinHeight="680"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <!-- No explicit Background here: this grid stays transparent so the Window's own solid
         BgBrush fill shows through the library and settings pages. PlayerView keeps its own
         solid fill since the editor is a dense workspace. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Single header strip: brand + page tabs on the left, live status in the middle,
             the action cluster on the right. No sidebar — with only two destinations, a
             full-height rail was mostly empty space. A drop shadow gives the strip real
             depth against the content below instead of a flat divider line. -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="20,0">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="14" Opacity="0.45"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/wispclip-small.png"
                           Width="38"
                           Height="38"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,16,0"/>

                    <Border Width="1" Height="22" Background="{StaticResource EdgeBrush}" Margin="0,0,14,0"/>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="NavLibrary"
                                     Style="{StaticResource NavTab}"
                                     Content="Library"
                                     Tag="M1,2 H7 V7 H1 Z M9,2 H15 V7 H9 Z M1,9 H7 V14 H1 Z M9,9 H15 V14 H9 Z"
                                     GroupName="Nav"
                                     IsChecked="True"
                                     Checked="Nav_Checked"/>
                        <RadioButton x:Name="NavSettings"
                                     Style="{StaticResource NavTab}"
                                     Content="Settings"
                                     Tag="M1,3 H15 V5 H1 Z M1,11 H15 V13 H1 Z M5,1 H8 V7 H5 Z M10,9 H13 V15 H10 Z"
                                     GroupName="Nav"
                                     Checked="Nav_Checked"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8"
                             Height="8"
                             Fill="{StaticResource TextDimBrush}"
                             VerticalAlignment="Center"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Starting"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="StatusDetailText"
                                   Text="Preparing capture"
                                   Margin="0,1,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource TextFaintBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action cluster: the buffer chip is a status toggle (secondary),
                     Record is a mode switch (secondary, outline), and Save clip is the
                     one filled/primary action — the only button meant to draw the eye. -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="BtnBuffer"
                                  Style="{StaticResource ChipToggle}"
                                  Click="BtnBuffer_Click"
                                  Margin="0,0,16,0"
                                  ToolTip="Keep the latest gameplay ready to save">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Width="11" Height="11"
                                  Data="M8,1 L14,3.2 L14,7.5 C14,11.3 11.5,13.9 8,15 C4.5,13.9 2,11.3 2,7.5 L2,3.2 Z"
                                  Margin="0,0,7,0"/>
                            <TextBlock x:Name="BufferLabel" Text="Buffer off" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button x:Name="BtnRecord"
                            Style="{StaticResource DangerButton}"
                            Click="BtnRecord_Click"
                            Margin="0,0,10,0"
                            ToolTip="Start or stop a full recording (Ctrl+Alt+R)">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="RecordGlyph"
                                    Width="9"
                                    Height="9"
                                    Background="{StaticResource DangerBrush}"
                                    CornerRadius="5"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"/>
                            <TextBlock x:Name="RecordLabel" Text="Record" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSaveReplay"
                            Style="{StaticResource AccentButton}"
                            Click="BtnSaveReplay_Click"
                            IsEnabled="False"
                            ToolTip="Save the protected replay (Ctrl+Alt+S)">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Fill="{StaticResource AccentForegroundBrush}"
                                  Data="M6,1 H10 V7 H14 L8,13 L2,7 H6 Z M2,14 H14 V16 H2 Z"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Save clip"
                                       Foreground="{StaticResource AccentForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <views:LibraryView x:Name="LibraryPage"/>
            <views:SettingsView x:Name="SettingsPage" Visibility="Collapsed"/>
        </Grid>

        <views:PlayerView x:Name="Player" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed"/>
    </Grid>
</Window>
